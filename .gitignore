# Secrets — never commit
.env
secrets/*
!secrets/.gitkeep
*service-account*.json
*.pem

# Raw ingested data — never commit (pulled locally per phase)
data/

# Python virtual environment
.venv/
venv/

# Python caches / build artifacts
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
build/
dist/

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Phase 3: dbt (transform/) — keep secrets + build artifacts out of git ---
# (transform/profiles.example.yml stays tracked as the template)
transform/profiles.yml
transform/target/
transform/dbt_packages/
transform/logs/
transform/.user.yml
