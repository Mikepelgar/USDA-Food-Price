# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# USDA FoodData Central API key (nutrition data)
# Request one at: https://fdc.nal.usda.gov/api-key-signup.html
FDC_API_KEY=

# USDA ERS key via api.data.gov (food price data)
# Request one at: https://api.data.gov/signup/
ERS_API_KEY=

# BLS Average Price Data API key (retail food prices). OPTIONAL: without it the
# ingestion falls back to the unauthenticated v1 endpoint (lower limits).
# Register at: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# Absolute or relative path to the Google Cloud service-account JSON
# used to authenticate to the data warehouse (e.g. BigQuery).
# Keep the actual JSON file out of git — store it under ./secrets/.
# NOTE (Phase 4): docker-compose OVERRIDES this inside the Airflow containers to
# /opt/airflow/secrets/gcp-service-account.json (the mounted JSON). This host value is
# still used when you run the scripts/dbt directly on your machine.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-service-account.json

# --- Phase 4: orchestration (Airflow in Docker) ---
# OS user id the Airflow containers run as, so files they write into mounted folders
# (e.g. data/raw/) aren't root-owned. On Linux/macOS set this to your `id -u`; on Windows
# the image default 50000 is fine.
AIRFLOW_UID=50000

# Admin login that the airflow-init service creates for the web UI (http://localhost:8080).
# Change these before exposing the stack anywhere beyond your laptop.
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
